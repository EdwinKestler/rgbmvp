{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "rgbmvp-public",
  "buildCommand": "mkdir -p public/artifacts/public && cp -r web/* public/ && cp -r artifacts/public/* public/artifacts/public/ && cp artifacts/public/manifest.json public/manifest.json",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/demo", "destination": "/demo.html" },
    { "source": "/audit", "destination": "/audit.html" },
    { "source": "/status", "destination": "/status.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
