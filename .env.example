# =============================================================================
# rgbmvp — non-secret template
# Copy to .env and fill in local values. Never commit .env.
#   cp .env.example .env
# =============================================================================

# --- Runtime ---
APP_ENV=development
LOG_LEVEL=info
# Network for public demos: liquid-testnet | liquid-regtest | bitcoin-testnet | bitcoin-signet
RGBMVP_NETWORK=liquid-testnet

# --- Project memory (optional Redis discovery cache; not asset storage) ---
# Default matches shared local Redis; no authentication.
RGBMVP_PROJECT_MEMORY_URL=redis://localhost:6379/0

# --- labd / API (Phase 0+) ---
# Operator default: loopback only. Public containers use PORT + LABD_PUBLIC_READ_ONLY=1.
LABD_BIND=127.0.0.1:8080
LABD_PUBLIC_BASE_URL=http://127.0.0.1:8080
# Comma-separated CORS origins (no * when LABD_PUBLIC_READ_ONLY=1)
LABD_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
# U4: public Internet posture — GET-only unless Bearer token presented
# LABD_PUBLIC_READ_ONLY=0
# LABD_API_TOKEN=
# LABD_MAX_BODY_BYTES=65536
# LABD_WEB_DIR=web
# LABD_ARTIFACTS_DIR=artifacts/public
# LABD_VERIFY_RATE_LIMIT=30

# --- Liquid (LWK / Elements) ---
# Prefer light clients for testnet; leave ELEMENTS_RPC_* empty unless you run a node.
LWK_NETWORK=testnet
# Electrum / Esplora endpoints (override if you use custom infra)
# Host:port for Electrum (TLS default on). Examples:
# LWK_ELECTRUM_URL=elements-testnet.blockstream.info:50002
# LWK_ELECTRUM_TLS=true
# LWK_ELECTRUM_VALIDATE_DOMAIN=true
# Esplora tip height URL used by `rgbmvp net status`:
# LWK_ESPLORA_TIP_URL=https://blockstream.info/liquidtestnet/api/blocks/tip/height
# Optional full node (not required for Phase 0 light mode)
# ELEMENTS_RPC_URL=http://127.0.0.1:18884
# ELEMENTS_RPC_USER=
# ELEMENTS_RPC_PASSWORD=

# --- P2 regtest: Elements with Simplicity (docker-compose default) ---
# ./scripts/regtest_simplicity.sh up  → host port 7042
# Credentials are regtest-only (match docker/elements-simplicity.conf). Never use on mainnet.
ELEMENTS_SIMPLICITY_RPC_URL=http://127.0.0.1:7042
ELEMENTS_RPC_USER=user
ELEMENTS_RPC_PASSWORD=pass
# Optional non-Simplicity Elements regtest (compose profile rgb-regtest, port 7041)
# ELEMENTS_RPC_URL=http://127.0.0.1:7041

# --- Bitcoin testnet (P1 HTLC / RGB twin swap) ---
BTC_NETWORK=testnet
BTC_ESPLORA_URL=https://blockstream.info/testnet/api
BTC_TESTNET_EXPLORER=https://blockstream.info/testnet
# Public address for btc-alice (safe to share on testnet)
# BTC_TESTNET_ADDRESS=tb1q…
# WIF for btc-alice — NEVER commit real values; only in local .env
# BTC_TESTNET_WIF=
# Optional bitcoind (not required if using Esplora broadcast)
# BITCOIN_RPC_URL=
# BITCOIN_RPC_USER=
# BITCOIN_RPC_PASSWORD=

# --- Optional lwk_cli JSON-RPC (if you run `lwk_cli server start`) ---
LWK_CLI_RPC_URL=http://127.0.0.1:32111

# --- Paths (local only; keep under gitignored dirs) ---
RGBMVP_DATA_DIR=.rgbmvp
RGBMVP_WALLET_DIR=.rgbmvp/wallets
RGBMVP_CONSIGNMENT_DIR=.rgbmvp/consignments

# --- Secrets (put real values only in .env — never commit) ---
# Demo faucet / issuer hot keys for TESTNET ONLY. Empty = disabled.
# RGBMVP_FAUCET_MNEMONIC=
# RGBMVP_ISSUER_MNEMONIC=
# --- Explorers (public links only) ---
LIQUID_TESTNET_EXPLORER=https://blockstream.info/liquidtestnet
BITCOIN_TESTNET_EXPLORER=https://blockstream.info/testnet
